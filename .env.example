# ----- Qdrant -----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ----- LLM (Ollama, local) -----
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3

# ----- Embeddings -----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- RAG tuning -----
CHUNK_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RAG_TOP_K=5

# ----- Upload -----
UPLOAD_DIR=/app/uploads
